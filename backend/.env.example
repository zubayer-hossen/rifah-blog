# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Local:      mongodb://127.0.0.1:27017/rifah-website
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rifah-website
MONGO_URI=mongodb://127.0.0.1:27017/rifah-website

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Admin (used once by `npm run seed:admin`) ----
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# ---- Cloudinary (image uploads for blog cover + gallery) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Nodemailer (contact form -> your inbox) ----
# For Gmail: enable 2FA then create an "App Password" — do not use your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CONTACT_RECEIVER_EMAIL=your_email@gmail.com
